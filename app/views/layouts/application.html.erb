<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Palette Wow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Palette Wow">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-neutral-900 font-sans antialiased min-h-screen flex flex-col">
    <nav class="border-b border-neutral-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <%= link_to "paletteWOW", root_path, class: "text-2xl font-black tracking-tighter hover:text-neutral-600 transition-colors" %>
          </div>
          <div class="flex items-center space-x-6">
            <% if user_signed_in? %>
              <span class="text-sm font-medium text-neutral-500"><%= current_user.email %></span>
              <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "text-sm font-medium hover:text-neutral-500 transition-colors bg-transparent border-none cursor-pointer" %>
            <% else %>
              <%= link_to "Log in", new_user_session_path, class: "text-sm font-medium hover:text-neutral-500 transition-colors" %>
              <%= link_to "Sign up", new_user_registration_path, class: "text-sm font-medium border border-black rounded-md px-4 py-2 hover:bg-black hover:text-white transition-colors" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="bg-black text-white px-4 py-3 text-center text-sm font-medium" role="alert">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-100 border-l-4 border-red-500 text-red-700 px-4 py-3 text-center text-sm font-medium" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col">
      <%= yield %>
    </main>
  </body>
</html>
