<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-controller="dashboard">
  <div class="flex justify-between items-center mb-8">
    <div class="flex items-center gap-4">
      <h1 class="text-4xl font-black tracking-tight">My Palettes</h1>
      
      <div class="hidden sm:flex items-center gap-2 ml-4">
        <button data-action="click->dashboard#exportLibrary" class="text-xs font-bold tracking-widest uppercase text-neutral-500 hover:text-black border border-neutral-200 hover:border-black rounded px-3 py-1.5 transition-colors cursor-pointer bg-white">
          Export
        </button>
        <button data-action="click->dashboard#triggerImport" class="text-xs font-bold tracking-widest uppercase text-neutral-500 hover:text-black border border-neutral-200 hover:border-black rounded px-3 py-1.5 transition-colors cursor-pointer bg-white">
          Import
        </button>
        <input type="file" accept=".json" class="hidden" data-dashboard-target="fileInput" data-action="change->dashboard#importLibrary">
      </div>
    </div>
    
    <%= link_to "Generate New", root_path, class: "bg-black text-white px-6 py-2 rounded-full font-medium hover:bg-neutral-800 transition" %>
  </div>
  
  <div class="flex sm:hidden items-center gap-2 mb-8">
    <button data-action="click->dashboard#exportLibrary" class="text-xs font-bold tracking-widest uppercase text-neutral-500 hover:text-black border border-neutral-200 hover:border-black rounded px-3 py-1.5 transition-colors cursor-pointer bg-white">
      Export JSON
    </button>
    <button data-action="click->dashboard#triggerImport" class="text-xs font-bold tracking-widest uppercase text-neutral-500 hover:text-black border border-neutral-200 hover:border-black rounded px-3 py-1.5 transition-colors cursor-pointer bg-white">
      Import JSON
    </button>
  </div>

  <div data-dashboard-target="container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <!-- Palettes are injected here by JS -->
  </div>

  <div data-dashboard-target="emptyState" class="hidden text-center py-20 bg-neutral-50 rounded-2xl border border-neutral-200 border-dashed">
    <h3 class="text-xl font-medium text-neutral-600 mb-2">You haven't saved any palettes yet.</h3>
    <p class="text-neutral-500 mb-6">Head over to the generator and start creating!</p>
    <%= link_to "Start Generating", root_path, class: "bg-black text-white px-6 py-3 rounded-full font-medium hover:bg-neutral-800 transition shadow-sm" %>
  </div>
</div>
