<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-controller="dashboard">
  <div class="flex justify-between items-center mb-8">
    <div class="flex items-center gap-4">
      <h1 class="text-4xl font-black tracking-tight">My Palettes</h1>
      
      <div class="hidden sm:flex items-center gap-2 ml-4">
        <button data-action="click->dashboard#exportLibrary" class="text-xs font-bold tracking-widest uppercase text-neutral-500 hover:text-black border border-neutral-200 hover:border-black rounded px-3 py-1.5 transition-colors cursor-pointer bg-white">
          Export
        </button>
        <button data-action="click->dashboard#triggerImport" class="text-xs font-bold tracking-widest uppercase text-neutral-500 hover:text-black border border-neutral-200 hover:border-black rounded px-3 py-1.5 transition-colors cursor-pointer bg-white">
          Import
        </button>
        <input type="file" accept=".json" class="hidden" data-dashboard-target="fileInput" data-action="change->dashboard#importLibrary">
      </div>
    </div>
    
    <%= link_to "Generate New", root_path, class: "bg-black text-white px-6 py-2 rounded-full font-medium hover:bg-neutral-800 transition" %>
  </div>
  
  <div class="flex sm:hidden items-center gap-2 mb-8">
    <button data-action="click->dashboard#exportLibrary" class="text-xs font-bold tracking-widest uppercase text-neutral-500 hover:text-black border border-neutral-200 hover:border-black rounded px-3 py-1.5 transition-colors cursor-pointer bg-white">
      Export JSON
    </button>
    <button data-action="click->dashboard#triggerImport" class="text-xs font-bold tracking-widest uppercase text-neutral-500 hover:text-black border border-neutral-200 hover:border-black rounded px-3 py-1.5 transition-colors cursor-pointer bg-white">
      Import JSON
    </button>
  </div>

  <% if @palettes.any? %>
    <div data-dashboard-target="container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @palettes.each do |palette| %>
        <div class="border border-neutral-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition" data-id="<%= palette.id %>" data-dashboard-target="paletteCard">
          <a href="/<%= palette.hex_codes.map { |h| h.delete('#') }.join('-') %>" class="flex h-32 w-full cursor-pointer hover:opacity-95 transition-opacity">
            <% palette.hex_codes.each do |hex| %>
              <div class="flex-1 h-full" style="background-color: <%= hex %>;"></div>
            <% end %>
          </a>
          
          <div class="p-4 flex justify-between items-center bg-white gap-4">
            <div class="flex-1 min-w-0" data-controller="inline-edit" data-inline-edit-id-value="<%= palette.id %>">
              <div class="flex items-center gap-2 group cursor-pointer" data-action="click->inline-edit#edit" data-inline-edit-target="display">
                <h3 class="font-bold text-lg truncate" data-inline-edit-target="text"><%= palette.name %></h3>
                <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-neutral-300 group-hover:text-black transition-colors shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" /></svg>
              </div>
              
              <form data-inline-edit-target="form" data-action="submit->inline-edit#save focusout->inline-edit#save" class="hidden flex items-center gap-2">
                <input type="text" data-inline-edit-target="input" value="<%= palette.name %>" class="w-full text-lg font-bold border-b border-black outline-none px-0 py-0 m-0 bg-transparent focus:ring-0">
              </form>
              
              <p class="text-xs text-neutral-500 mt-1"><%= palette.created_at.strftime("%B %e, %Y") %></p>
            </div>
            
            <button data-action="click->dashboard#deletePalette" data-id="<%= palette.id %>" class="text-red-500 hover:text-red-700 p-2 rounded-full hover:bg-red-50 transition cursor-pointer shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20 bg-neutral-50 rounded-2xl border border-neutral-200 border-dashed">
      <h3 class="text-xl font-medium text-neutral-600 mb-2">You haven't saved any palettes yet.</h3>
      <p class="text-neutral-500 mb-6">Head over to the generator and start creating!</p>
      <%= link_to "Start Generating", root_path, class: "bg-black text-white px-6 py-3 rounded-full font-medium hover:bg-neutral-800 transition shadow-sm" %>
    </div>
  <% end %>
</div>
