<div class="fixed inset-0 pt-16 flex flex-col" data-controller="palette" data-palette-logo-url-value="<%= image_path('logo.png') %>" data-palette-saved-patterns-value="<%= @saved_hex_patterns.to_json %>" data-action="keydown@window->palette#handleKeydown" <%= "data-palette-initial-colors-value=\"#{CGI.escapeHTML(@colors.to_json)}\"".html_safe if defined?(@colors) && @colors.present? %>>
  
  <!-- Top Bar: Actions (Desktop Only) -->
  <div class="hidden md:flex h-16 w-full bg-white border-b border-neutral-200 px-6 items-center justify-between shrink-0 z-10">
    <!-- Left: Undo / Redo / Spacebar Info -->
    <div class="flex items-center space-x-4">
      <p class="text-[12px] font-medium tracking-widest text-neutral-400 flex items-center">
        Press <strong class="text-neutral-900 mx-1.5">Spacebar</strong> to generate 
      </p>

      <div class="h-4 w-px bg-neutral-200"></div>

      <div class="flex items-center space-x-1">
        <button data-action="click->palette#undo" class="p-1.5 text-neutral-400 hover:text-black transition-colors rounded hover:bg-neutral-100" title="Undo (Cmd+Z)">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" /></svg>
        </button>
        <button data-action="click->palette#redo" class="p-1.5 text-neutral-400 hover:text-black transition-colors rounded hover:bg-neutral-100" title="Redo (Cmd+Shift+Z)">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 15l6-6m0 0l-6-6m6 6H9a6 6 0 000 12h3" /></svg>
        </button>
      </div>

      <div class="h-4 w-px bg-neutral-200"></div>

      <div class="relative flex items-center group cursor-pointer" title="Generation Method">
        <div class="p-1.5 text-neutral-400 bg-transparent transition-colors rounded group-hover:text-black group-hover:bg-neutral-100 flex items-center justify-center">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" /></svg>
        </div>
        <select data-action="change->palette#changeMethod" data-palette-target="methodSelect" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
          <option value="auto">Random</option>
          <option value="monochromatic">Monochromatic</option>
          <option value="analogous">Analogous</option>
          <option value="complementary">Complementary</option>
          <option value="split_complementary">Split Complementary</option>
          <option value="triadic">Triadic</option>
          <option value="tetradic">Tetradic</option>
          <option value="square">Square</option>
        </select>
      </div>
    </div>

    <!-- Right: Actions -->
    <div class="flex items-center space-x-4">
      <button data-action="click->palette#openExportModal" class="flex items-center space-x-2 text-[12px] font-bold tracking-widest uppercase text-black px-4 py-2.5 rounded transition-colors bg-white hover:bg-neutral-50 border border-neutral-300 shadow-sm cursor-pointer hover:border-neutral-400">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
        <span>Export</span>
      </button>

      <div class="h-5 w-px bg-neutral-200"></div>

      <% if user_signed_in? %>
        <button data-action="click->palette#save" class="flex items-center space-x-2 text-[12px] font-bold tracking-widest uppercase text-black px-4 py-2.5 rounded transition-colors bg-white hover:bg-neutral-50 border border-neutral-300 shadow-sm cursor-pointer hover:border-black group">
          <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 shrink-0 text-neutral-300 group-hover:text-black transition-colors stroke-black stroke-2"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          <span>Save</span>
        </button>
      <% else %>
        <%= button_to '/auth/google_oauth2', method: :post, data: { turbo: false }, class: "flex items-center space-x-2 text-[12px] font-bold tracking-widest uppercase text-black px-4 py-2.5 rounded transition-colors bg-white hover:bg-neutral-50 border border-neutral-300 shadow-sm cursor-pointer hover:border-black group" do %>
          <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 shrink-0 text-neutral-300 group-hover:text-black transition-colors stroke-black stroke-2"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          <span>Save</span>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Generators -->
  <div class="flex flex-col md:flex-row flex-1 w-full pb-[calc(72px+env(safe-area-inset-bottom))] md:pb-0 relative max-h-full min-h-0" data-palette-target="container">
    <!-- Multiply by 5 columns -->
    <% 5.times do |i| %>
      <div 
        class="flex-1 flex flex-row md:flex-col justify-between md:justify-end items-center px-6 sm:px-8 md:px-0 py-0 md:pb-[15%] transition-colors duration-200 group relative shadow-none min-h-0 overflow-hidden"
        data-palette-target="column"
        data-locked="false"
      >
        <!-- Center Tools (Lock, etc) - Right aligned on mobile, absolute center on desktop -->
        <div class="flex-none order-2 md:order-none flex justify-end md:justify-center items-center h-full md:absolute md:inset-0 z-20 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300 md:pointer-events-none md:-translate-y-12 shrink">
          <div class="flex flex-col md:gap-2 items-center md:pointer-events-auto h-full justify-center shrink min-h-0">
             
             <!-- Desktop Tool Placeholders -->
             <button data-action="click->palette#addColumn" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Add color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"></path></svg></button>
             <button data-action="click->palette#removeColumn" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Remove color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg></button>
             <button data-action="click->palette#viewShades" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="View shades"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"></path></svg></button>
             <div class="hidden md:flex p-1 opacity-50 hover:opacity-100 transition-opacity cursor-grab active:cursor-grabbing js-drag-handle" title="Drag"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg></div>
             <button class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Copy hex" data-action="click->palette#copyHex"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"></path></svg></button>

             <button data-action="click->palette#toggleLock" class="p-2 transition-opacity active:scale-95 opacity-50 hover:opacity-100 group-[&[data-locked=true]]:opacity-100">
                <!-- Unlocked Icon -->
                <svg data-palette-target="unlockedIcon" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path d="M18 1.5c2.9 0 5.25 2.35 5.25 5.25v3.75a.75.75 0 0 1-1.5 0V6.75a3.75 3.75 0 1 0-7.5 0v3a3 3 0 0 1 3 3v6.75a3 3 0 0 1-3 3H3.75a3 3 0 0 1-3-3v-6.75a3 3 0 0 1 3-3h9v-3c0-2.9 2.35-5.25 5.25-5.25Z"></path></svg>
                <!-- Locked Icon -->
                <svg data-palette-target="lockedIcon" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6 hidden"><path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.25 8.25v-3a3.25 3.25 0 1 0-6.5 0v3h6.5Z" clip-rule="evenodd"></path></svg>
             </button>
          </div>
        </div>
        
        <!-- Hex Code (Left on mobile, bottom on desktop) -->
        <div class="flex-none order-1 md:order-none flex justify-start md:justify-center items-center h-full md:h-auto z-10 md:w-full transition-opacity duration-300 pointer-events-none md:pointer-events-auto mt-auto md:absolute md:bottom-[15%] shrink min-h-0">
           <!-- Mobile drag handle and delete icons -->
           <div class="flex flex-col justify-evenly h-full py-1 sm:py-2 mr-3 sm:mr-4 md:hidden pointer-events-auto shrink-0 min-h-[60px]">
             <button data-action="click->palette#addColumn" class="p-0.5 sm:p-1 opacity-50 active:opacity-100 transition-opacity flex-1 flex items-center justify-center min-h-[20px]" title="Add color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 sm:w-5 sm:h-5 pointer-events-none drop-shadow-sm"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"></path></svg></button>
             <button data-action="click->palette#removeColumn" class="p-0.5 sm:p-1 opacity-50 active:opacity-100 transition-opacity flex-1 flex items-center justify-center min-h-[20px]" title="Remove color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 sm:w-5 sm:h-5 pointer-events-none drop-shadow-sm"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg></button>
             <div class="p-0.5 sm:p-1 opacity-50 active:opacity-100 transition-opacity cursor-grab active:cursor-grabbing js-drag-handle flex-1 flex items-center justify-center min-h-[20px]"><svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 sm:w-5 sm:h-5 pointer-events-none drop-shadow-sm"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg></div>
           </div>
           
           <div class="flex flex-col justify-center h-full md:items-center text-left md:text-center mt-0 md:mt-4 pointer-events-auto shrink min-h-0">
             <h2 class="text-base sm:text-[17px] md:text-2xl font-bold tracking-widest uppercase cursor-pointer opacity-70 hover:opacity-100 active:opacity-50 transition-opacity font-sans relative group/hex" data-palette-target="hexCode" data-action="click->palette#openColorPicker">
               <span class="inline-block">FFFFFF</span>
               <span class="absolute -top-10 left-1/2 -translate-x-1/2 bg-black text-white text-xs px-2 py-1 rounded shadow opacity-0 group-[.copied]/hex:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Copied!</span>
               <input type="color" data-action="input->palette#updateColorFromPicker change->palette#saveColorFromPicker" class="absolute w-0 h-0 opacity-0 pointer-events-none" tabindex="-1">
             </h2>
             <span class="block text-[10px] sm:text-[11px] font-medium opacity-50 capitalize tracking-wider mt-1 mix-blend-color-burn text-center" data-palette-target="colorName">Color Name</span>
           </div>
        </div>



        <!-- Shades Overlay -->
        <div data-palette-target="shadesModal" class="absolute inset-0 z-40 hidden flex-col opacity-0 transition-opacity duration-300 pointer-events-auto">
          <button data-action="click->palette#closeShades" class="absolute top-2 right-2 text-white p-2 hover:scale-110 transition-transform drop-shadow-md z-50 opacity-80 hover:opacity-100 flex items-center justify-center bg-black/20 rounded-full backdrop-blur-sm shadow-sm md:top-4 md:right-4">
            <svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 lg:w-4 lg:h-4"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg>
          </button>
          
          <div data-palette-target="shadesContainer" class="flex-1 flex flex-col w-full h-full">
            <!-- Swatches will be injected here -->
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Mobile Fixed Action Bar (Bottom) -->
  <div class="fixed bottom-0 left-0 right-0 md:hidden z-20 bg-white border-t border-neutral-100 shadow-[0_-2px_10px_rgba(0,0,0,0.02)] pb-[env(safe-area-inset-bottom)]">
    <div class="h-[72px] flex items-center justify-between px-6">
      
      <!-- Left Tools: Undo / Redo -->
      <div class="flex items-center space-x-3 sm:space-x-5 text-neutral-800">
        <button data-action="click->palette#undo" class="p-1 text-neutral-600 active:opacity-50 transition-opacity" title="Undo">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" /></svg>
        </button>
        <button data-action="click->palette#redo" class="p-1 text-neutral-600 active:opacity-50 transition-opacity" title="Redo">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15 15l6-6m0 0l-6-6m6 6H9a6 6 0 000 12h3" /></svg>
        </button>
      </div>

      <!-- Center: Generate Text Button & Save -->
      <div class="absolute left-1/2 -translate-x-1/2 flex flex-row items-center">
        <button data-action="click->palette#generate" class="text-base sm:text-lg font-bold tracking-wide active:opacity-50 transition-colors border border-neutral-300 bg-white hover:bg-neutral-50 rounded-md px-4 sm:px-6 py-2 shadow-sm">
          Generate
        </button>
      </div>
    
      <!-- Right Tools: Options / Menu -->
      <div class="flex items-center space-x-3 sm:space-x-5 text-neutral-800">
        <% if user_signed_in? %>
          <button data-action="click->palette#save" class="p-1 active:opacity-50 transition-opacity group flex items-center justify-center">
            <svg fill="currentColor" viewBox="0 0 24 24" class="w-7 h-7 text-white group-hover:text-black transition-colors stroke-neutral-900 stroke-2"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          </button>
        <% else %>
          <%= button_to '/auth/google_oauth2', method: :post, data: { turbo: false }, class: "p-1 active:opacity-50 transition-opacity group flex items-center justify-center bg-transparent border-none cursor-pointer text-white hover:text-black transition-colors stroke-neutral-900 stroke-2" do %>
            <svg fill="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          <% end %>
        <% end %>

        <div class="relative flex items-center group cursor-pointer active:opacity-50 transition-opacity" title="Generation Method">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" /></svg>
          <select data-action="change->palette#changeMethod" data-palette-target="methodSelect" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
            <option value="auto">Random</option>
            <option value="monochromatic">Monochromatic</option>
            <option value="analogous">Analogous</option>
            <option value="complementary">Complementary</option>
            <option value="split_complementary">Split Comp</option>
            <option value="triadic">Triadic</option>
            <option value="tetradic">Tetradic</option>
            <option value="square">Square</option>
          </select>
        </div>
        <button data-action="click->palette#openExportModal" class="active:opacity-50 transition-opacity">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
        </button>
      </div>
      
    </div>
  </div>

  <!-- Export Modal -->
  <div data-palette-target="exportModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity opacity-0" data-palette-target="exportBackdrop" data-action="click->palette#closeExportModal"></div>
    
    <!-- Modal Content -->
    <div class="relative w-full max-w-lg bg-white rounded-2xl shadow-2xl p-6 sm:p-8 transform scale-95 opacity-0 transition-all duration-300" data-palette-target="exportContent">
      <div class="absolute top-4 right-4">
        <button data-action="click->palette#closeExportModal" class="p-2 text-neutral-400 hover:text-black hover:bg-neutral-100 rounded-full transition-colors cursor-pointer">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      
      <h3 class="text-2xl font-black tracking-tight text-center mb-2">Export Palette</h3>
      <p class="text-neutral-500 text-sm text-center mb-8">Download your colors or copy them for your next project.</p>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        <!-- Export Actions -->
        <button data-action="click->palette#exportImage" class="group flex flex-col items-center justify-center p-4 border border-neutral-200 rounded-xl hover:border-black hover:bg-neutral-50 transition-all cursor-pointer">
          <div class="w-12 h-12 flex items-center justify-center bg-black text-white rounded-full mb-3 group-hover:scale-110 transition-transform">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
          </div>
          <span class="text-sm font-bold tracking-wide uppercase">Image (PNG)</span>
        </button>

        <button data-action="click->palette#exportPdf" class="group flex flex-col items-center justify-center p-4 border border-neutral-200 rounded-xl hover:border-black hover:bg-neutral-50 transition-all cursor-pointer">
          <div class="w-12 h-12 flex items-center justify-center bg-black text-white rounded-full mb-3 group-hover:scale-110 transition-transform">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
          </div>
          <span class="text-sm font-bold tracking-wide uppercase">PDF</span>
        </button>

        <button data-action="click->palette#copyUrl" class="group flex flex-col items-center justify-center p-4 border border-neutral-200 rounded-xl hover:border-black hover:bg-neutral-50 transition-all cursor-pointer">
          <div class="w-12 h-12 flex items-center justify-center bg-black text-white rounded-full mb-3 group-hover:scale-110 transition-transform">
