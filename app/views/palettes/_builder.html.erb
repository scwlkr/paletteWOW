</div>

<!-- Template for New Column -->
<template id="column-template">
  <!-- (Existing column template from origin) -->
  <div 
    class="flex-1 flex flex-row md:flex-col justify-between md:justify-end items-center px-6 sm:px-8 md:px-0 py-0 md:pb-[15%] transition-colors duration-200 group relative shadow-none min-h-0 overflow-hidden"
    data-palette-target="column"
    data-locked="false"
  >
    <!-- Center Tools (Lock, etc) -->
    <div class="flex-none order-2 md:order-none flex justify-end md:justify-center items-center h-full md:absolute md:inset-0 z-20 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300 md:pointer-events-none md:-translate-y-12 shrink">
      <div class="flex flex-col md:gap-2 items-center md:pointer-events-auto h-full justify-center shrink min-h-0">
         <!-- Desktop Tool Placeholders -->
         <button data-action="click->palette#addColumn" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Add color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"></path></svg></button>
         <button data-action="click->palette#removeColumn" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Remove color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg></button>
         <button data-action="click->palette#viewShades" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="View shades"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"></path></svg></button>
         <div class="hidden md:flex p-1 opacity-50 hover:opacity-100 transition-opacity cursor-grab active:cursor-grabbing js-drag-handle" title="Drag"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg></div>
         <button class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Copy hex" data-action="click->palette#copyHex"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"></path></svg></button>

         <button data-action="click->palette#toggleLock" class="p-2 transition-opacity active:scale-95 opacity-50 hover:opacity-100 group-[&[data-locked=true]]:opacity-100">
            <!-- Unlocked Icon -->
            <svg data-palette-target="unlockedIcon" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path d="M18 1.5c2.9 0 5.25 2.35 5.25 5.25v3.75a.75.75 0 0 1-1.5 0V6.75a3.75 3.75 0 1 0-7.5 0v3a3 3 0 0 1 3 3v6.75a3 3 0 0 1-3 3H3.75a3 3 0 0 1-3-3v-6.75a3 3 0 0 1 3-3h9v-3c0-2.9 2.35-5.25 5.25-5.25Z"></path></svg>
            <!-- Locked Icon -->
            <svg data-palette-target="lockedIcon" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6 hidden"><path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.25 8.25v-3a3.25 3.25 0 1 0-6.5 0v3h6.5Z" clip-rule="evenodd"></path></svg>
         </button>
      </div>
    </div>
    
    <!-- Hex Code -->
    <div class="flex-none order-1 md:order-none flex justify-start md:justify-center items-center h-full md:h-auto z-10 md:w-full transition-opacity duration-300 pointer-events-none md:pointer-events-auto mt-auto md:absolute md:bottom-[15%] shrink min-h-0">
       <div class="flex flex-col justify-evenly h-full py-1 sm:py-2 mr-3 sm:mr-4 md:hidden pointer-events-auto shrink-0 min-h-[60px]">
         <button data-action="click->palette#addColumn" class="p-0.5 sm:p-1 opacity-50 active:opacity-100 transition-opacity flex-1 flex items-center justify-center min-h-[20px]" title="Add color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 sm:w-5 sm:h-5 pointer-events-none drop-shadow-sm"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"></path></svg></button>
         <button data-action="click->palette#removeColumn" class="p-0.5 sm:p-1 opacity-50 active:opacity-100 transition-opacity flex-1 flex items-center justify-center min-h-[20px]" title="Remove color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 sm:w-5 sm:h-5 pointer-events-none drop-shadow-sm"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg></button>
         <div class="p-0.5 sm:p-1 opacity-50 active:opacity-100 transition-opacity cursor-grab active:cursor-grabbing js-drag-handle flex-1 flex items-center justify-center min-h-[20px]"><svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4 sm:w-5 sm:h-5 pointer-events-none drop-shadow-sm"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg></div>
       </div>
       
       <div class="flex flex-col justify-center h-full md:items-center text-left md:text-center mt-0 md:mt-4 pointer-events-auto shrink min-h-0">
         <h2 class="text-base sm:text-[17px] md:text-2xl font-bold tracking-widest uppercase cursor-pointer opacity-70 hover:opacity-100 active:opacity-50 transition-opacity font-sans relative group/hex" data-palette-target="hexCode" data-action="click->palette#openColorPicker">
           <span class="inline-block">FFFFFF</span>
           <span class="absolute -top-10 left-1/2 -translate-x-1/2 bg-black text-white text-xs px-2 py-1 rounded shadow opacity-0 group-[.copied]/hex:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Copied!</span>
           <input type="color" data-action="input->palette#updateColorFromPicker change->palette#saveColorFromPicker" class="absolute w-0 h-0 opacity-0 pointer-events-none" tabindex="-1">
         </h2>
         <span class="block text-[10px] sm:text-[11px] font-medium opacity-50 capitalize tracking-wider mt-1 mix-blend-color-burn text-center" data-palette-target="colorName">Color Name</span>
