        <button data-action="click->palette#copySvg" class="group flex flex-col items-center justify-center p-4 border border-neutral-200 rounded-xl hover:border-black hover:bg-neutral-50 transition-all cursor-pointer">
          <div class="w-12 h-12 flex items-center justify-center bg-black text-white rounded-full mb-3 group-hover:scale-110 transition-transform font-black text-xs">
            SVG
          </div>
          <span class="text-sm font-bold tracking-wide uppercase">Copy SVG</span>
