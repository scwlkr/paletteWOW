<div class="fixed inset-0 pt-16 flex flex-col" data-controller="palette" data-action="keydown@window->palette#handleKeydown">
  
  <!-- Top Bar: Actions (Desktop Only) -->
  <div class="hidden md:flex h-16 w-full bg-white border-b border-neutral-200 px-6 items-center justify-between shrink-0 z-10">
    <!-- Left: Undo / Redo / Spacebar Info -->
    <div class="flex items-center space-x-4">
      <p class="text-[12px] font-medium tracking-widest text-neutral-400 flex items-center">
        Press <strong class="text-neutral-900 mx-1.5">Spacebar</strong> to generate 
      </p>

      <div class="h-4 w-px bg-neutral-200"></div>

      <div class="flex items-center space-x-1">
        <button data-action="click->palette#undo" class="p-1.5 text-neutral-400 hover:text-black transition-colors rounded hover:bg-neutral-100" title="Undo (Cmd+Z)">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" /></svg>
        </button>
        <button data-action="click->palette#redo" class="p-1.5 text-neutral-400 hover:text-black transition-colors rounded hover:bg-neutral-100" title="Redo (Cmd+Shift+Z)">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 15l6-6m0 0l-6-6m6 6H9a6 6 0 000 12h3" /></svg>
        </button>
      </div>

      <div class="h-4 w-px bg-neutral-200"></div>

      <select data-action="change->palette#changeMethod" data-palette-target="methodSelect" class="appearance-none bg-transparent border-none text-[12px] font-bold tracking-widest uppercase text-black cursor-pointer outline-none focus:ring-0 p-0 m-0 leading-none h-auto">
        <option value="auto">Auto</option>
        <option value="monochromatic">Monochromatic</option>
        <option value="analogous">Analogous</option>
        <option value="complementary">Complementary</option>
        <option value="split_complementary">Split Complementary</option>
        <option value="triadic">Triadic</option>
        <option value="tetradic">Tetradic</option>
        <option value="square">Square</option>
      </select>
    </div>

    <!-- Right: Actions -->
    <div class="flex items-center space-x-4">
      <button class="flex items-center space-x-2 text-[12px] font-bold tracking-widest uppercase text-black px-4 py-2.5 rounded transition-colors bg-white hover:bg-neutral-50 border border-neutral-300 shadow-sm cursor-pointer hover:border-neutral-400">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
        <span>Export</span>
      </button>

      <div class="h-5 w-px bg-neutral-200"></div>

      <% if user_signed_in? %>
        <button data-action="click->palette#save" class="flex items-center space-x-2 text-[12px] font-bold tracking-widest uppercase text-black px-4 py-2.5 rounded transition-colors bg-white hover:bg-neutral-50 border border-neutral-300 shadow-sm cursor-pointer hover:border-neutral-400">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" /></svg>
          <span>Save</span>
        </button>
      <% else %>
        <%= button_to '/auth/google_oauth2', method: :post, data: { turbo: false }, class: "flex items-center space-x-2 text-[12px] font-bold tracking-widest uppercase text-black px-4 py-2.5 rounded transition-colors bg-white hover:bg-neutral-50 border border-neutral-300 shadow-sm cursor-pointer hover:border-neutral-400" do %>
          <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" /></svg>
          <span>Save</span>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Generators -->
  <div class="flex flex-col md:flex-row flex-1 w-full pb-[72px] md:pb-0 relative" data-palette-target="container">
    <!-- Multiply by 5 columns -->
    <% 5.times do |i| %>
      <div 
        class="flex-1 flex flex-row md:flex-col justify-between md:justify-end items-center px-8 md:px-0 py-0 md:pb-[15%] transition-colors duration-200 group relative shadow-none"
        data-palette-target="column"
        data-locked="false"
      >
        <!-- Center Tools (Lock, etc) - Right aligned on mobile, absolute center on desktop -->
        <div class="flex-none order-2 md:order-none flex justify-end md:justify-center items-center md:absolute md:inset-0 z-20 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300 md:pointer-events-none md:-translate-y-12">
          <div class="flex flex-col md:gap-2 items-center md:pointer-events-auto">
             
             <!-- Desktop Tool Placeholders -->
             <button data-action="click->palette#addColumn" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Add color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"></path></svg></button>
             <button data-action="click->palette#removeColumn" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Remove color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg></button>
             <button data-action="click->palette#viewShades" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="View shades"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"></path></svg></button>
             <button class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Save color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path></svg></button>
             <div class="hidden md:flex p-1 opacity-50 hover:opacity-100 transition-opacity cursor-grab active:cursor-grabbing js-drag-handle" title="Drag"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg></div>
             <button class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Copy hex" data-action="click->palette#copyHex"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"></path></svg></button>

             <button data-action="click->palette#toggleLock" class="p-2 transition-opacity active:scale-95 opacity-50 hover:opacity-100 group-[&[data-locked=true]]:opacity-100">
                <!-- Unlocked Icon -->
                <svg data-palette-target="unlockedIcon" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path d="M18 1.5c2.9 0 5.25 2.35 5.25 5.25v3.75a.75.75 0 0 1-1.5 0V6.75a3.75 3.75 0 1 0-7.5 0v3a3 3 0 0 1 3 3v6.75a3 3 0 0 1-3 3H3.75a3 3 0 0 1-3-3v-6.75a3 3 0 0 1 3-3h9v-3c0-2.9 2.35-5.25 5.25-5.25Z"></path></svg>
                <!-- Locked Icon -->
                <svg data-palette-target="lockedIcon" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6 hidden"><path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.25 8.25v-3a3.25 3.25 0 1 0-6.5 0v3h6.5Z" clip-rule="evenodd"></path></svg>
             </button>
          </div>
        </div>
        
        <!-- Hex Code (Left on mobile, bottom on desktop) -->
        <div class="flex-none order-1 md:order-none flex justify-start md:justify-center items-center h-full md:h-auto z-10 md:w-full transition-opacity duration-300 pointer-events-none md:pointer-events-auto mt-auto md:absolute md:bottom-[15%]">
           <!-- Mobile drag handle and delete icons -->
           <div class="flex flex-col gap-3 mr-4 md:hidden pointer-events-auto">
             <button data-action="click->palette#addColumn" class="p-1 opacity-50 active:opacity-100 transition-opacity" title="Add color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"></path></svg></button>
             <button data-action="click->palette#removeColumn" class="p-1 opacity-50 active:opacity-100 transition-opacity" title="Remove color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg></button>
             <div class="p-1 opacity-50 active:opacity-100 transition-opacity cursor-grab active:cursor-grabbing js-drag-handle"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg></div>
           </div>
           
           <div class="flex flex-col md:items-center text-left md:text-center mt-0 md:mt-4 pointer-events-auto">
             <h2 class="text-[17px] md:text-2xl font-bold tracking-widest uppercase cursor-pointer opacity-70 hover:opacity-100 active:opacity-50 transition-opacity font-sans relative group/hex" data-palette-target="hexCode" data-action="click->palette#copyHex">
               <span class="inline-block">FFFFFF</span>
               <span class="absolute -top-10 left-1/2 -translate-x-1/2 bg-black text-white text-xs px-2 py-1 rounded shadow opacity-0 group-[.copied]/hex:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Copied!</span>
             </h2>
             <span class="hidden md:block text-[11px] font-medium opacity-50 capitalize tracking-widest mt-1 mix-blend-color-burn">Color Name</span>
           </div>
        </div>



        <!-- Shades Overlay -->
        <div data-palette-target="shadesModal" class="absolute inset-0 z-40 hidden flex-col opacity-0 transition-opacity duration-300 pointer-events-auto">
          <button data-action="click->palette#closeShades" class="absolute top-2 right-2 text-white p-2 hover:scale-110 transition-transform drop-shadow-md z-50 opacity-80 hover:opacity-100 flex items-center justify-center bg-black/20 rounded-full backdrop-blur-sm shadow-sm md:top-4 md:right-4">
            <svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 lg:w-4 lg:h-4"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg>
          </button>
          
          <div data-palette-target="shadesContainer" class="flex-1 flex flex-col w-full h-full">
            <!-- Swatches will be injected here -->
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Mobile Fixed Action Bar (Bottom) -->
  <div class="fixed bottom-0 left-0 right-0 md:hidden z-20 bg-white h-[72px] flex items-center justify-between px-6 border-t border-neutral-100 shadow-[0_-2px_10px_rgba(0,0,0,0.02)]">
    
    <!-- Left Tools: Undo / Redo -->
    <div class="flex items-center space-x-6 text-neutral-800">
      <button data-action="click->palette#undo" class="active:opacity-50 transition-opacity">
        <svg fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"></path></svg>
      </button>
      <button data-action="click->palette#redo" class="active:opacity-50 transition-opacity">
        <svg fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path d="M10.707 17.707 16.414 12l-5.707-5.707-1.414 1.414L13.586 12l-4.293 4.293z"></path></svg>
      </button>
    </div>

    <!-- Center: Generate Text Button -->
    <div class="flex flex-col items-center -ml-4">
      <button data-action="click->palette#generate" class="text-lg font-medium tracking-wide active:opacity-50 transition-opacity">
        Generate
      </button>
      <select data-action="change->palette#changeMethod" data-palette-target="methodSelect" class="appearance-none bg-transparent border-none text-[10px] font-semibold tracking-widest uppercase text-neutral-400 cursor-pointer outline-none focus:ring-0 text-center p-0 m-0 leading-none">
        <option value="auto">Auto</option>
        <option value="monochromatic">Monochromatic</option>
        <option value="analogous">Analogous</option>
        <option value="complementary">Complementary</option>
        <option value="split_complementary">Split Comp</option>
        <option value="triadic">Triadic</option>
        <option value="tetradic">Tetradic</option>
        <option value="square">Square</option>
      </select>
    </div>
    
    <!-- Right Tools: Options / Menu -->
    <div class="flex items-center space-x-7 text-neutral-800">
      <button class="active:opacity-50 transition-opacity">
        <svg fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><circle cx="5" cy="12" r="2"></circle><circle cx="12" cy="12" r="2"></circle><circle cx="19" cy="12" r="2"></circle></svg>
      </button>
      <button class="active:opacity-50 transition-opacity">
        <svg fill="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"></path></svg>
      </button>
    </div>
    
  </div>
</div>

<!-- Template for New Column -->
<template id="column-template">
  <div 
    class="flex-1 flex flex-row md:flex-col justify-between md:justify-end items-center px-8 md:px-0 py-0 md:pb-[15%] transition-colors duration-200 group relative shadow-none"
    data-palette-target="column"
    data-locked="false"
  >
    <!-- Center Tools (Lock, etc) -->
    <div class="flex-none order-2 md:order-none flex justify-end md:justify-center items-center md:absolute md:inset-0 z-20 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300 md:pointer-events-none md:-translate-y-12">
      <div class="flex flex-col md:gap-2 items-center md:pointer-events-auto">
         <!-- Desktop Tool Placeholders -->
         <button data-action="click->palette#addColumn" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Add color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"></path></svg></button>
         <button data-action="click->palette#removeColumn" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Remove color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg></button>
         <button data-action="click->palette#viewShades" class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="View shades"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"></path></svg></button>
         <button class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Save color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path></svg></button>
         <div class="hidden md:flex p-1 opacity-50 hover:opacity-100 transition-opacity cursor-grab active:cursor-grabbing js-drag-handle" title="Drag"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg></div>
         <button class="hidden md:block p-1 opacity-50 hover:opacity-100 transition-opacity" title="Copy hex" data-action="click->palette#copyHex"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"></path></svg></button>

         <button data-action="click->palette#toggleLock" class="p-2 transition-opacity active:scale-95 opacity-50 hover:opacity-100 group-[&[data-locked=true]]:opacity-100">
            <!-- Unlocked Icon -->
            <svg data-palette-target="unlockedIcon" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6"><path d="M18 1.5c2.9 0 5.25 2.35 5.25 5.25v3.75a.75.75 0 0 1-1.5 0V6.75a3.75 3.75 0 1 0-7.5 0v3a3 3 0 0 1 3 3v6.75a3 3 0 0 1-3 3H3.75a3 3 0 0 1-3-3v-6.75a3 3 0 0 1 3-3h9v-3c0-2.9 2.35-5.25 5.25-5.25Z"></path></svg>
            <!-- Locked Icon -->
            <svg data-palette-target="lockedIcon" fill="currentColor" viewBox="0 0 24 24" class="w-6 h-6 hidden"><path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.25 8.25v-3a3.25 3.25 0 1 0-6.5 0v3h6.5Z" clip-rule="evenodd"></path></svg>
         </button>
      </div>
    </div>
    
    <!-- Hex Code -->
    <div class="flex-none order-1 md:order-none flex justify-start md:justify-center items-center h-full md:h-auto z-10 md:w-full transition-opacity duration-300 pointer-events-none md:pointer-events-auto mt-auto md:absolute md:bottom-[15%]">
       <div class="flex flex-col gap-3 mr-4 md:hidden pointer-events-auto">
         <button data-action="click->palette#addColumn" class="p-1 opacity-50 active:opacity-100 transition-opacity" title="Add color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"></path></svg></button>
         <button data-action="click->palette#removeColumn" class="p-1 opacity-50 active:opacity-100 transition-opacity" title="Remove color"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path></svg></button>
         <div class="p-1 opacity-50 active:opacity-100 transition-opacity cursor-grab active:cursor-grabbing js-drag-handle"><svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 pointer-events-none"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg></div>
       </div>
       
       <div class="flex flex-col md:items-center text-left md:text-center mt-0 md:mt-4 pointer-events-auto">
         <h2 class="text-[17px] md:text-2xl font-bold tracking-widest uppercase cursor-pointer opacity-70 hover:opacity-100 active:opacity-50 transition-opacity font-sans relative group/hex" data-palette-target="hexCode" data-action="click->palette#copyHex">
           <span class="inline-block">FFFFFF</span>
           <span class="absolute -top-10 left-1/2 -translate-x-1/2 bg-black text-white text-xs px-2 py-1 rounded shadow opacity-0 group-[.copied]/hex:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Copied!</span>
         </h2>
         <span class="hidden md:block text-[11px] font-medium opacity-50 capitalize tracking-widest mt-1 mix-blend-color-burn">Color Name</span>
       </div>
    </div>



