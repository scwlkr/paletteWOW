<div class="fixed inset-0 pt-16" data-controller="palette" data-action="keydown@window->palette#handleKeydown">
  <!-- Top Bar: Actions -->
  <div class="absolute top-16 left-0 right-0 z-10 flex justify-between items-center px-8 py-4 pointer-events-none">
    <p class="text-sm font-semibold tracking-widest uppercase bg-white/80 backdrop-blur-sm px-4 py-2 rounded-full border border-neutral-200 pointer-events-auto">
      Press <kbd class="px-2 py-1 bg-neutral-100 rounded text-xs font-mono ml-1">Spacebar</kbd> to generate
    </p>

    <div class="pointer-events-auto flex items-center space-x-4">
      <% if user_signed_in? %>
        <button class="bg-black text-white px-6 py-2 rounded-full font-medium hover:bg-neutral-800 transition shadow-lg flex items-center gap-2">
          <!-- Save Icon -->
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
          Save Palette
        </button>
      <% else %>
        <%= link_to "Login to Save", new_user_session_path, class: "bg-white text-black border border-neutral-200 px-6 py-2 rounded-full font-medium hover:bg-neutral-50 transition shadow-sm" %>
      <% end %>
    </div>
  </div>

  <!-- Generators -->
  <div class="flex flex-col md:flex-row h-full w-full">
    <!-- Multiply by 5 columns -->
    <% 5.times do |i| %>
      <div 
        class="flex-1 flex flex-col justify-end items-center pb-24 md:pb-32 transition-colors duration-200 group relative"
        data-palette-target="column"
        data-locked="false"
      >
        <!-- Color Info -->
        <div class="flex flex-col items-center gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 md:opacity-100 mb-8 z-10">
          <h2 class="text-3xl md:text-4xl font-black uppercase tracking-wider uppercase cursor-pointer hover:scale-110 transition-transform" data-palette-target="hexCode" data-action="click->palette#copyHex">#FFFFFF</h2>
          
          <button data-action="click->palette#toggleLock" class="p-3 bg-white/20 hover:bg-white/40 rounded-full backdrop-blur-sm border border-black/10 transition-colors">
             <!-- Unlocked Icon (default) -->
             <svg data-palette-target="unlockedIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>
             <!-- Locked Icon (hidden initially) -->
             <svg data-palette-target="lockedIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          </button>
        </div>
      </div>
    <% end %>
  </div>
</div>
