<div class="w-full max-w-md mx-auto mt-20 p-8 border border-neutral-200 rounded-lg shadow-sm bg-white text-neutral-900">
  <h2 class="text-3xl font-extrabold mb-6 tracking-tight text-center">Create Account</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-neutral-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full border-neutral-300 rounded-md shadow-sm focus:border-black focus:ring-black sm:text-sm p-2 border" %>
    </div>

    <div>
      <div class="flex items-center justify-between">
        <%= f.label :password, class: "block text-sm font-medium text-neutral-700 mb-1" %>
        <% if @minimum_password_length %>
          <span class="text-xs text-neutral-500">(<%= @minimum_password_length %> chars min)</span>
        <% end %>
      </div>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full border-neutral-300 rounded-md shadow-sm focus:border-black focus:ring-black sm:text-sm p-2 border" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-neutral-700 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full border-neutral-300 rounded-md shadow-sm focus:border-black focus:ring-black sm:text-sm p-2 border" %>
    </div>

    <div>
      <%= f.submit "Sign Up", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-black hover:bg-neutral-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black cursor-pointer transition-colors" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm">
    <%= render "devise/shared/links" %>
  </div>
</div>
