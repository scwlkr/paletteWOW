<div class="w-full max-w-md mx-auto mt-20 p-8 border border-neutral-200 rounded-lg shadow-sm bg-white text-neutral-900">
  <h2 class="text-3xl font-extrabold mb-6 tracking-tight text-center">Welcome Back</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-neutral-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full border-neutral-300 rounded-md shadow-sm focus:border-black focus:ring-black sm:text-sm p-2 border" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-neutral-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full border-neutral-300 rounded-md shadow-sm focus:border-black focus:ring-black sm:text-sm p-2 border" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center">
        <%= f.check_box :remember_me, class: "h-4 w-4 text-black focus:ring-black border-neutral-300 rounded" %>
        <%= f.label :remember_me, class: "ml-2 block text-sm text-neutral-900" %>
      </div>
    <% end %>

    <div>
      <%= f.submit "Log In", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-black hover:bg-neutral-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black cursor-pointer transition-colors" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm">
    <%= render "devise/shared/links" %>
  </div>
</div>
